---
type NavLink = {
	path: string;
	label: string;
};

const links: NavLink[] = [
	{
		path: "#portfolio",
		label: "Portfolio",
	},
	{
		path: "#contact",
		label: "Contact",
	},
];
---

<header
	class="h-16 sticky top-0 flex items-center w-full bg-base-950 px-4 py-2"
>
	<a href="/" class="font-semibold p-3"> lionpuro.com </a>

	<div class="ml-auto flex">
		<nav class="flex">
			{
				links.map((link) => (
					<a
						data-astro-prefetch
						href={link.path}
						class="text-sm sm:text-base p-2 sm:p-3 font-semibold text-base-100"
					>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>
</header>
